    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^10.16.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "next-themes": "^0.4.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
